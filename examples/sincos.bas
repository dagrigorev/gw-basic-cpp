10 SCREEN 2: CLS
20 KEY OFF: COLOR 15,0

30 REM CENTER
40 CX = 320
50 CY = 100

60 REM SCALE
70 SX = 40
80 SY = 60

90 PI = 3.1415926535

100 REM DRAW AXES
110 LINE (0,CY)-(639,CY), 7
120 LINE (CX,0)-(CX,199), 7

130 REM X AXIS MARKS
140 FOR I = -6 TO 6
150 X = CX + I * SX
160 LINE (X,CY-3)-(X,CY+3), 7
170 LOCATE 14, (X/8)-1: PRINT I
180 NEXT I

190 REM Y AXIS MARKS
200 FOR I = -1 TO 1
210 Y = CY - I * SY
220 LINE (CX-3,Y)-(CX+3,Y), 7
230 LOCATE (Y/8), 41: PRINT I
240 NEXT I

250 REM LABELS
260 LOCATE 2, 35: PRINT "SIN (green)  COS (red)"

270 REM DRAW SIN
280 PX = CX - 6 * SX
290 PY = CY - SIN(-6) * SY

300 FOR X = -6 TO 6 STEP 0.05
310 NX = CX + X * SX
320 NY = CY - SIN(X) * SY
330 LINE (PX,PY)-(NX,NY), 10
340 PX = NX: PY = NY
350 NEXT X

360 REM DRAW COS
370 PX = CX - 6 * SX
380 PY = CY - COS(-6) * SY

390 FOR X = -6 TO 6 STEP 0.05
400 NX = CX + X * SX
410 NY = CY - COS(X) * SY
420 LINE (PX,PY)-(NX,NY), 12
430 PX = NX: PY = NY
440 NEXT X

450 END