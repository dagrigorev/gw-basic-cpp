10 SCREEN 2
20 CLS
30 COLOR 15, 0
40 REM PI ESTIMATE BY PI-XEL COUNTING
50 REM COUNTS PIXELS INSIDE A QUARTER CIRCLE
60 R = 90
70 X0 = 40
80 Y0 = 105
90 INSIDE = 0
100 TOTAL = 0
110 FOR Y = 0 TO R
120   FOR X = 0 TO R
130     TOTAL = TOTAL + 1
140     D2 = X * X + Y * Y
150     IF D2 <= R * R THEN INSIDE = INSIDE + 1: PSET (X0 + X, Y0 - Y), 10 ELSE PSET (X0 + X, Y0 - Y), 8
160   NEXT X
170 NEXT Y
180 LINE (X0, Y0)-(X0 + R, Y0), 15
190 LINE (X0, Y0)-(X0, Y0 - R), 15
200 CIRCLE (X0, Y0), R, 14
210 PI = 4 * INSIDE / TOTAL
220 LOCATE 1, 1
230 PRINT "PI-XEL PI ESTIMATE"
240 PRINT "RADIUS:"; R
250 PRINT "INSIDE:"; INSIDE
260 PRINT "TOTAL:"; TOTAL
270 PRINT "PI:"; PI
280 PRINT "ERROR:"; ABS(PI - 3.14159265358979)
290 END
