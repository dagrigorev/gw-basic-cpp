10 SCREEN 2: CLS
20 KEY OFF: COLOR 15, 0

30 REM CONFIG
40 CW = 6
50 CH = 6
60 W = 106
70 H = 33
80 LN = 8
90 SC = 0

100 REM STATE
110 HX = 50
120 HY = 16
130 DX = 1
140 DY = 0

150 DIM BX(1000), BY(1000)

160 FOR I = 1 TO LN
170 BX(I) = HX - I
180 BY(I) = HY
190 NEXT I

200 GOSUB 1000
210 GOSUB 1400
220 GOSUB 1600
230 LOCATE 1, 1: PRINT "SCORE:"; SC; "   "

240 REM MAIN LOOP
250 K$ = INKEY$
260 IF K$ <> "" THEN GOSUB 800

270 TX = BX(LN)
280 TY = BY(LN)

290 FOR I = LN TO 2 STEP -1
300 BX(I) = BX(I-1)
310 BY(I) = BY(I-1)
320 NEXT I

330 BX(1) = HX
340 BY(1) = HY

350 HX = HX + DX
360 HY = HY + DY

370 IF HX < 0 THEN HX = W - 1
380 IF HX >= W THEN HX = 0
390 IF HY < 0 THEN HY = H - 1
400 IF HY >= H THEN HY = 0

410 FOR I = 2 TO LN
420 IF HX = BX(I) AND HY = BY(I) THEN GOTO 2000
430 NEXT I

440 GROW = 0
450 IF HX = FX AND HY = FY THEN GROW = 1: GOSUB 1800

460 IF GROW = 0 THEN GOSUB 1200
470 IF GROW = 0 THEN IF ABS(TX - FX) <= 1 AND ABS(TY - FY) <= 1 THEN GOSUB 1400

480 GOSUB 1650
490 GOSUB 1700
500 GOTO 250

800 REM INPUT
810 IF K$ = "W" OR K$ = "w" THEN IF DY = 0 THEN DX = 0: DY = -1
820 IF K$ = "S" OR K$ = "s" THEN IF DY = 0 THEN DX = 0: DY = 1
830 IF K$ = "A" OR K$ = "a" THEN IF DX = 0 THEN DX = -1: DY = 0
840 IF K$ = "D" OR K$ = "d" THEN IF DX = 0 THEN DX = 1: DY = 0
850 IF K$ = CHR$(27) THEN GOTO 2000
860 RETURN

1000 REM SPAWN APPLE
1010 FX = INT(RND * W)
1020 FY = INT(RND * H)
1030 FOR I = 1 TO LN
1040 IF FX = BX(I) AND FY = BY(I) THEN GOTO 1010
1050 NEXT I
1060 RETURN

1200 REM ERASE OLD TAIL ONLY
1210 PX = TX * CW + 3
1220 PY = TY * CH + 12
1230 LINE (PX-4, PY-4)-(PX+4, PY+4), 0, BF
1240 RETURN

1400 REM DRAW APPLE
1410 AX = FX * CW + 3
1420 AY = FY * CH + 12
1430 CIRCLE (AX, AY), 2, 4
1440 PAINT (AX, AY), 4, 4
1450 PSET (AX - 1, AY - 1), 12
1460 LINE (AX, AY - 3)-(AX, AY - 5), 2
1470 PSET (AX + 1, AY - 4), 2
1480 RETURN

1600 REM DRAW WHOLE INITIAL SNAKE
1610 FOR I = LN TO 2 STEP -1
1620 SX = BX(I) * CW + 3
1630 SY = BY(I) * CH + 12
1640 RR = 1
1650 IF I < LN - 2 THEN RR = 2
1660 IF I < LN - 5 THEN RR = 3
1670 CIRCLE (SX, SY), RR, 10
1680 PAINT (SX, SY), 10, 10
1690 NEXT I
1695 RETURN

1650 REM DRAW NEW BODY SEGMENT ONLY
1660 SX = BX(1) * CW + 3
1670 SY = BY(1) * CH + 12
1680 CIRCLE (SX, SY), 3, 10
1690 PAINT (SX, SY), 10, 10
1695 RETURN

1700 REM DRAW HEAD
1710 SX = HX * CW + 3
1720 SY = HY * CH + 12
1730 CIRCLE (SX, SY), 2, 14
1740 PAINT (SX, SY), 14, 14
1750 PSET (SX - 1, SY - 1), 15
1760 PSET (SX + 1, SY - 1), 15
1770 RETURN

1800 REM GROW SNAKE AND RESPAWN APPLE
1810 LN = LN + 1
1820 BX(LN) = BX(LN - 1)
1830 BY(LN) = BY(LN - 1)
1840 SC = SC + 10
1850 GOSUB 1000
1860 GOSUB 1400
1870 RETURN

2000 REM GAME OVER
2010 SOUND 500, 1
2020 SOUND 300, 2
2030 LOCATE 12, 35: PRINT "GAME OVER"
2040 LOCATE 13, 33: PRINT "FINAL SCORE:"; SC
2050 END