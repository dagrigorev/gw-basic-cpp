10 SCREEN 2: CLS
20 KEY OFF: COLOR 15,0

30 REM =========================
40 REM MINIMAL RAYCASTING DEMO
50 REM W/S - FORWARD/BACK
60 REM A/D - STRAFE
70 REM Q/E - TURN
80 REM ESC - EXIT
90 REM =========================

100 MW = 16
110 MH = 12

120 M1$  = "################"
130 M2$  = "#..............#"
140 M3$  = "#..####........#"
150 M4$  = "#..............#"
160 M5$  = "#......##......#"
170 M6$  = "#......##......#"
180 M7$  = "#..............#"
190 M8$  = "#....######....#"
200 M9$  = "#..............#"
210 M10$ = "#..............#"
220 M11$ = "#..............#"
230 M12$ = "################"

240 PX = 3.5
250 PY = 3.5
260 PA = 0

270 FOV = 1.0472
280 RAYS = 80
290 STEPANG = FOV / RAYS
300 MAXD = 20
310 DEPTHSTEP = 0.08
320 PROJ = 800

330 GOTO 500

500 REM MAIN LOOP
510 GOSUB 3000
520 K$ = INKEY$
530 IF K$ <> "" THEN GOSUB 4000
540 GOTO 500

3000 REM RENDER FRAME
3010 LINE (0,0)-(639,99), 1, BF
3020 LINE (0,100)-(639,199), 8, BF

3030 RA = PA - FOV / 2
3040 COLW = 640 / RAYS

3050 FOR R = 0 TO RAYS - 1
3060   D = 0.1

3070   REM CAST ONE RAY
3080   RX = PX + COS(RA) * D
3090   RY = PY + SIN(RA) * D
3100   MX = INT(RX)
3110   MY = INT(RY)

3120   IF MX < 0 OR MX >= MW OR MY < 0 OR MY >= MH THEN GOTO 3200

3130   GOSUB 6000
3140   C$ = MID$(ROW$, MX + 1, 1)
3150   IF C$ = "#" THEN GOTO 3200

3160   D = D + DEPTHSTEP
3170   IF D < MAXD THEN GOTO 3080

3200   REM FISHEYE CORRECTION
3210   CD = D * COS(RA - PA)
3220   IF CD < 0.1 THEN CD = 0.1

3230   H = INT(PROJ / CD)
3240   IF H > 180 THEN H = 180

3250   Y1 = 100 - H / 2
3260   Y2 = 100 + H / 2
3270   X1 = INT(R * COLW)
3280   X2 = INT((R + 1) * COLW)

3290   REM SIMPLE DISTANCE SHADING
3300   COL = 15
3310   IF CD > 2 THEN COL = 7
3320   IF CD > 4 THEN COL = 8
3330   IF CD > 6 THEN COL = 9
3340   IF CD > 8 THEN COL = 1

3350   LINE (X1,Y1)-(X2,Y2), COL, BF

3360   RA = RA + STEPANG
3370 NEXT R

3380 REM UI
3390 COLOR 14,0: LOCATE 1,2: PRINT "MINI RAYCASTER"
3400 COLOR 15,0: LOCATE 2,2: PRINT "W/S MOVE  A/D STRAFE  Q/E TURN  ESC EXIT"
3410 RETURN

4000 REM INPUT
4010 IF K$ = CHR$(27) THEN END

4020 IF K$ = "Q" OR K$ = "q" THEN PA = PA - 0.12
4030 IF K$ = "E" OR K$ = "e" THEN PA = PA + 0.12

4040 IF PA < 0 THEN PA = PA + 6.28318
4050 IF PA > 6.28318 THEN PA = PA - 6.28318

4060 NX = PX
4070 NY = PY

4080 IF K$ = "W" OR K$ = "w" THEN NX = PX + COS(PA) * 0.20: NY = PY + SIN(PA) * 0.20
4090 IF K$ = "S" OR K$ = "s" THEN NX = PX - COS(PA) * 0.20: NY = PY - SIN(PA) * 0.20

4100 IF K$ = "A" OR K$ = "a" THEN NX = PX + COS(PA - 1.5708) * 0.20: NY = PY + SIN(PA - 1.5708) * 0.20
4110 IF K$ = "D" OR K$ = "d" THEN NX = PX + COS(PA + 1.5708) * 0.20: NY = PY + SIN(PA + 1.5708) * 0.20

4120 TX = INT(NX)
4130 TY = INT(NY)
4140 IF TX < 0 OR TX >= MW OR TY < 0 OR TY >= MH THEN RETURN

4150 GOSUB 6100
4160 C$ = MID$(ROW$, TX + 1, 1)
4170 IF C$ = "#" THEN RETURN

4180 PX = NX
4190 PY = NY
4200 RETURN

6000 REM GET MAP ROW FOR MY
6010 IF MY = 0 THEN ROW$ = M1$
6020 IF MY = 1 THEN ROW$ = M2$
6030 IF MY = 2 THEN ROW$ = M3$
6040 IF MY = 3 THEN ROW$ = M4$
6050 IF MY = 4 THEN ROW$ = M5$
6060 IF MY = 5 THEN ROW$ = M6$
6070 IF MY = 6 THEN ROW$ = M7$
6080 IF MY = 7 THEN ROW$ = M8$
6090 IF MY = 8 THEN ROW$ = M9$
6092 IF MY = 9 THEN ROW$ = M10$
6094 IF MY = 10 THEN ROW$ = M11$
6096 IF MY = 11 THEN ROW$ = M12$
6098 RETURN

6100 REM GET MAP ROW FOR TY
6110 IF TY = 0 THEN ROW$ = M1$
6120 IF TY = 1 THEN ROW$ = M2$
6130 IF TY = 2 THEN ROW$ = M3$
6140 IF TY = 3 THEN ROW$ = M4$
6150 IF TY = 4 THEN ROW$ = M5$
6160 IF TY = 5 THEN ROW$ = M6$
6170 IF TY = 6 THEN ROW$ = M7$
6180 IF TY = 7 THEN ROW$ = M8$
6190 IF TY = 8 THEN ROW$ = M9$
6192 IF TY = 9 THEN ROW$ = M10$
6194 IF TY = 10 THEN ROW$ = M11$
6196 IF TY = 11 THEN ROW$ = M12$
6198 RETURN