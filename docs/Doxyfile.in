PROJECT_NAME           = "GW-BASIC Modern Rewrite"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@GWBASIC_DOXYGEN_OUTPUT_DIR@"
INPUT                  = @GWBASIC_DOXYGEN_INPUT@
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.md
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = @PROJECT_SOURCE_DIR@
